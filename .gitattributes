# Auto detect text files and normalize line endings
* text=auto

# C# source files
*.cs text diff=csharp
*.csproj text
*.sln text
*.slnx text
*.axaml text
*.xaml text
*.xml text
*.json text
*.manifest text

# Markdown
*.md text

# Shell scripts
*.sh text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.ico binary
*.icns binary
*.png binary
*.jpg binary
*.dll binary
*.exe binary

# JavaScript (bundled mermaid)
*.js text
