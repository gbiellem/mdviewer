<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:MdView.Models"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="480"
        x:Class="MdView.Views.EditorPickerWindow"
        Title="Choose Editor"
        Width="420" Height="480"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowDecorations="Full">

    <Window.Resources>
        <!-- macOS-style ListBoxItem: full-row rounded highlight, no accent bar -->
        <ControlTheme x:Key="MacListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="^:selected:pointerover">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
            <Style Selector="^:selected:pressed">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
        </ControlTheme>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Click="OnCancelClick" Padding="16,6" />
                <Button x:Name="SelectButton"
                        Content="Select"
                        Click="OnSelectClick"
                        IsEnabled="False"
                        Padding="16,6" />
            </StackPanel>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock x:Name="LoadingText"
                   Text="Detecting editors..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.6"
                   IsVisible="True" />

        <!-- Editor list -->
        <ListBox x:Name="EditorList"
                 IsVisible="False"
                 Background="Transparent"
                 BorderThickness="0"
                 SelectionChanged="OnEditorSelectionChanged"
                 DoubleTapped="OnEditorDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:EditorInfo">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Image Width="32" Height="32"
                               Source="{Binding Icon}"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
